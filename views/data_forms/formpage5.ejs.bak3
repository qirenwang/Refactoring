                        <div class="form-row">
                            <label class="form-label">PA (Polyamide) / Nylon:</label>
                            <input type="number" name="fragment_polymer_pa" class="form-input" placeholder="percentage" min="0" max="100">
                        </div>
                        <div class="form-row">
                            <label class="form-label">PC (Polycarbonate):</label>
                            <input type="number" name="fragment_polymer_pc" class="form-input" placeholder="percentage" min="0" max="100">
