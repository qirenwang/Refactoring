# Docker ignore file - Reduce build context size
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime files
*.log
logs/
uploads/*
!uploads/.gitkeep

# Development tools
.git
.gitignore
README.md
.env.local
.env.development
.env.test

# IDE and editors
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Temporary files
tmp/
temp/
.tmp

# Test files
test/
tests/
*.test.js
*.spec.js

# Development configuration
nodemon.json
.eslintrc*
.prettierrc*

# Docker related
Dockerfile*
docker-compose*
.dockerignore
