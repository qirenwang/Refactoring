<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="icon" href="/assets/mpicon.ico" sizes="64x64">    <link rel="stylesheet" href="/css/auth-pages.css">
</head>
<body>
    <div class="container">
        <div class="header">
            <div class="logo-container">
                <a href="/home">
                    <img src="/assets/Logo-MicroPlastics_09.png" alt="MicroPlastics Logo">
                </a>
            </div>
            <h1 class="form-title">Sign Up</h1>
            <p class="form-subtitle">Create your account</p>
        </div>
        
        <div class="form-container">
            <% if (locals.error) { %>
                <div class="error-message">
                    <%= error %>
                </div>
            <% } %>
            
            <form id="signupForm" action="/auth/signup" method="POST">
                <div class="form-group">
                    <label class="form-label" for="username">Username:</label>
                    <input type="text" id="username" name="username" class="form-input" required minlength="3">
                    <div class="password-requirements">Minimum 3 characters</div>
                </div>
                
                <div class="form-group">
                    <label class="form-label" for="email">Email:</label>
                    <input type="email" id="email" name="email" class="form-input" required>
                </div>
                
                <div class="form-group">
                    <label class="form-label" for="password">Password:</label>
                    <input type="password" id="password" name="password" class="form-input" required minlength="6">
                    <div class="password-requirements">Minimum 6 characters</div>
                </div>
                
                <div class="form-group">
                    <label class="form-label" for="confirm_password">Confirm Password:</label>
                    <input type="password" id="confirm_password" name="confirm_password" class="form-input" required>
                </div>
                
                <div class="form-group">
                    <label class="form-label" for="captcha">Verification Code:</label>
                    <div class="captcha-container">
                        <img id="captcha-image" src="/auth/captcha" alt="Captcha" class="captcha-image" 
                             onclick="refreshCaptcha()" title="Click to refresh">
                        <input type="text" id="captcha" name="captcha" class="form-input captcha-input" 
                               placeholder="Enter code" required>
                    </div>
                </div>
                
                <button type="submit" class="btn">Create Account</button>
            </form>
        </div>
        
        <div class="form-footer">
            <p>Already have an account? <a href="/login">Login here</a></p>
        </div>
    </div>    <script>
        function refreshCaptcha() {
            const captchaImage = document.getElementById('captcha-image');
            captchaImage.src = '/auth/captcha?' + Math.random();
            document.getElementById('captcha').value = '';        }    </script>
    <script src="/js/auth.js"></script>
    
    <!-- Disable Stagewise Toolbar for auth pages -->
    <% if (false && process.env.NODE_ENV !== 'production') { %>
        <script src="/js/stagewise-toolbar.js"></script>
    <% } %>
</body>
</html>
