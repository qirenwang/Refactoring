<script>
// Data quality control for Page 5
(function () {
    const TOLERANCE = 0.5; // +/- percent allowed to account for rounding

    function getContainer(id) {
        return document.getElementById(id);
    }

    function getInputsByNames(container, names) {
        const sel = names.map(n => `input[name="${n}"]`).join(',');
        return Array.from(container.querySelectorAll(sel));
    }

    function getInputsByPattern(container, pattern) {
        const re = new RegExp(pattern);
        return Array.from(container.querySelectorAll('input[name]')).filter(i => re.test(i.name));
    }

    function groupSum(inputs) {
        let hasAny = false;
        let sum = 0;
        inputs.forEach(i => {
            const v = i.value.trim();
            if (v !== '') {
                const num = parseFloat(v);
                if (!isNaN(num)) {
                    hasAny = true;
                    sum += num;
                }
            }
        });
        return { hasAny, sum };
    }

    function validateGroups() {
        const errors = [];

        const configs = [
            // Microplastics
            { id: 'microplastics-details', label: 'Microplastics - Size', names: ['mp_size_lt_1um','mp_size_1_20um','mp_size_20_100um','mp_size_100um_1mm','mp_size_1_5mm'] },
            { id: 'microplastics-details', label: 'Microplastics - Color type', names: ['fragment_color_clear','fragment_color_opaque_light','fragment_color_opaque_dark','fragment_color_mixed'] },
            { id: 'microplastics-details', label: 'Microplastics - Form', names: ['mp_form_fiber','mp_form_pellet','mp_form_fragment'] },
            { id: 'microplastics-details', label: 'Microplastics - Polymer type', pattern: '^mp_polymer_' },

            // Fragments
            { id: 'fragments-details', label: 'Fragments - Color type', names: ['fragment_color_clear','fragment_color_opaque_light','fragment_color_opaque_dark','fragment_color_mixed'] },
            { id: 'fragments-details', label: 'Fragments - Form', names: ['fragment_form_fiber','fragment_form_pellet','fragment_form_film','fragment_form_foam','fragment_form_hardplastic','fragment_form_other'] },
            { id: 'fragments-details', label: 'Fragments - Polymer type', pattern: '^fragment_polymer_' },
        ];

        configs.forEach(cfg => {
            const container = getContainer(cfg.id);
            if (!container) return;
            const inputs = cfg.names ? getInputsByNames(container, cfg.names)
                                                             : getInputsByPattern(container, cfg.pattern);
            if (!inputs.length) return;
            const { hasAny, sum } = groupSum(inputs);
            if (!hasAny) return; // Section empty -> OK
            if (Math.abs(sum - 100) > TOLERANCE) {
                errors.push(`${cfg.label}: totals ${sum.toFixed(2)}% (must equal 100% or leave all blank)`);
            }
        });

        return errors;
    }

    // Intercept the Continue click for page 5 and show issues, without breaking navigation on success
    document.addEventListener('click', function (e) {
        const btn = e.target && e.target.closest('#form-page5 .btn-continue[data-next="6"]');
        if (!btn) return;
        const errors = validateGroups();
        if (errors.length) {
            e.preventDefault();
            e.stopPropagation();
            if (typeof e.stopImmediatePropagation === 'function') e.stopImmediatePropagation();
            alert('Please review your percentage entries:\n\n' + errors.map((er, i) => `${i+1}. ${er}`).join('\n'));
        }
    }, true);
})();
</script>
