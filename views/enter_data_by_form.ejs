<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Enter Data by Form - Microplastics Data Entry</title>
    <link rel="icon" href="/assets/mpicon.ico" sizes="64x64">
    <!-- Add Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.7.1/dist/leaflet.css" />    <!-- Add Font Awesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Add Custom CSS -->
    <link rel="stylesheet" href="/css/mp_style.css">
    <!-- Add Fancy Modal CSS -->
    <link rel="stylesheet" href="/css/fancy-modal.css">
    <!-- Add Custom JS -->
    <script src="/js/common.js"></script>
    
    <!-- Stagewise Toolbar for Development -->
    <% if (process.env.NODE_ENV !== 'production') { %>
        <script src="/js/stagewise-toolbar.js"></script>
    <% } %>
</head>
<body>
<div class="container">
    <%- include('partials/header') %>
    
    <div class="content">
        <%- include('partials/sidebar') %>
      <div class="main-content">
        <div class="form-progress-container">
            <div class="form-progress">
                <div class="progress-step active" data-step="1">
                    <span class="step-number">1</span>
                    <span class="step-label">Location</span>
                </div>
                <div class="progress-step" data-step="2">
                    <span class="step-number">2</span>
                    <span class="step-label">Sampling Event</span>
                </div>
                <div class="progress-step" data-step="3">
                    <span class="step-number">3</span>
                    <span class="step-label">Media Information</span>
                </div>
                <div class="progress-step" data-step="4">
                    <span class="step-number">4</span>
                    <span class="step-label">Additional Information</span>
                </div>
                <div class="progress-step" data-step="5">
                    <span class="step-number">5</span>
                    <span class="step-label">Particle Details</span>
                </div>
                <div class="progress-step" data-step="6">
                    <span class="step-number">6</span>
                    <span class="step-label">Confirmation</span>
                </div>
            </div>
        </div>
        
        <!-- Form Pages Container -->
        <div class="form-pages-container">
            <!-- Page 1: Location Information - Initially visible -->
            <div class="form-page" id="form-page1" data-page="1">
                <h2 class="form-section-title">Location Information</h2>
                <div class="instruction">
                    <span class="bold">Choose ONE</span> of the 2 ways below to enter the sampling location. Reuse a previous location for repeat sampling, or enter a new location and then provide location details using coordinates, a full indoor address, or a ZIP code for approximate area only.
                </div>
                <div class="location-options">
                    <div class="option">
                        <span class="option-number">1</span>
                        <span class="option-title">Select previously sampled location</span> (repeat sampling)
                        <div class="select-container">
                            <select id="location-select" class="location-select" name="location_id">
                                <option value="">-- Select a location --</option>
                            </select>
                            <div id="location-loading" class="location-loading">Loading locations...</div>
                        </div>
                    </div>                    <div class="option">
                        <span class="option-number">2</span>
                        <!-- # add a note here -->
                        <span class="option-title">Enter new location</span>
                        <div class="instruction-note" style="color: #e74c3c; background-color: #fdf2f2; padding: 8px; margin: 8px 0; border-left: 4px solid #e74c3c; font-size: 14px;">
                            <strong>Important:</strong> To create a brand new location, clear "Select previously sampled location" first. If an existing location is selected, only location description and coordinates are treated as event-level overrides.
                        </div>
                        <div class="location-form">                            <div class="form-row">
                                <label class="form-label">Location Name (<span style="color: red;">*</span>, for pull-down menu):</label>
                            </div>
                            <div class="form-row">
                                <input type="text" id="location-name" name="location_name" class="form-input" placeholder="Enter location name">
                            </div>

                            <div class="form-row">
                                <label class="form-label">Location Short Code (<span style="color: red;">*</span>, for quickly identifying location types, such as a storm drain or lake, see documentation):</label>
                            </div>
                            <div class="form-row">
                                <input type="text" id="location-shortcode" name="location_shortcode" class="form-input" placeholder="For quickly identifying location types, such as a storm drain or lake, see documentation.">
                            </div>

                            <div class="form-row">
                                <label class="form-label">Location Description (<span style="color: red;">*</span>):</label>
                            </div>
                            <div class="form-row">
                                <input type="text" id="location-description" name="location_description" class="form-input" placeholder="Enter location description">
                            </div>

                            <div class="form-row">
                                <label class="form-label">Land Use and Land Cover (LULC) (<span style="color: red;">*</span>):</label>
                            </div>
                            <div class="form-row">
                                <select id="land-use-cover" name="land_use_cover" class="form-input" required>
                                    <option value="">-- Select Land Use and Land Cover --</option>
                                    <option value="water">Water</option>
                                    <option value="trees">Trees</option>
                                    <option value="flooded_vegetation">Flooded Vegetation</option>
                                    <option value="crops">Crops</option>
                                    <option value="built_area">Built Area</option>
                                    <option value="bare_ground">Bare Ground</option>
                                    <option value="snow_ice">Snow/Ice</option>
                                    <option value="rangeland">Rangeland</option>
                                </select>
                            </div>

                            <div class="instruction" style="margin-top: 10px;">
                                For new locations, use <span class="bold">latitude/longitude</span> for precise outdoor sampling points, <span class="bold">full address + Find Address on Map</span> for indoor samples, or <span class="bold">ZIP code</span> when you can only share an approximate area.
                            </div>

                            <span class="form-label"><span class="bold">For outdoor:</span></span>
                            <div class="coordinates-container">
                                <div class="coordinate-field">
                                    <div class="coordinate-label">Latitude (click map)</div>
                                    <input type="text" id="latitude" name="latitude" class="coordinate-input" placeholder="Enter latitude">
                                </div>
                                <div class="coordinate-field">
                                    <div class="coordinate-label">Longitude</div>
                                    <input type="text" id="longitude" name="longitude" class="coordinate-input" placeholder="Enter longitude">
                                </div>
                            </div>
                            
                            <div class="coordinate-hint">Click the map to set coordinates, drag the marker to refine them, or type latitude and longitude manually.</div>
                            
                            <!-- Map container -->
                            <div id="map"></div>
                            
                            <div class="form-row">
                                <label class="form-label">Acres (if sampling a broad area):</label>
                                <input type="text" id="acres" name="acres" class="form-input" placeholder="Enter area in acres">
                            </div>


                            <span class="form-label"><span class="bold">For indoor:</span> Full address</span>
                            <div class="coordinate-hint" style="margin-top: 6px;">Enter the full address, then select <span class="bold">Find Address on Map</span> to place the marker. Review the point and drag it if needed.</div>
                            <input type="text" name="streetaddress" class="input-field" placeholder="StreetAddress">
                            <div style="display: flex; gap: 8px; margin-top: 8px;">
                                <input type="text" name="city" class="input-field" placeholder="City" style="flex:1;">
                                <input type="text" name="state" class="input-field" placeholder="State" style="flex:1;">
                                <input type="text" name="country" class="input-field" placeholder="Country" style="flex:1;">
                            </div>
                            <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap; margin-top: 10px;">
                                <button type="button" id="find-address-on-map" class="btn-continue" style="width: auto; padding: 8px 14px;">Find Address on Map</button>
                                <div id="address-geocode-status" style="font-size: 13px; line-height: 1.4;"></div>
                            </div>
                            

                            <span class="form-label">Or ZIP code only</span> (for confidential data or samples collected over a wide area):
                            <div class="coordinate-hint" style="margin-top: 6px;">ZIP code is kept for approximate area reporting only. It will not place a precise point on the map.</div>
                            <input type="text" name="zip_code" class="input-field" placeholder="zip code">
                        </div>


                    </div>
                </div>
                <div class="form-navigation">
                    <button type="button" id="page1-continue" class="btn-continue" data-next="2">Continue</button>
                </div>
            </div>
        </div>
          <!-- Templates for form pages that will be loaded progressively -->
        <div style="display: none;" id="form-templates">
            <!-- Page 2: Sampling Event Information -->
            <%- include('data_forms/formpage2') %>

            <!-- Page 3: Media Selection -->
            <%- include('data_forms/formpage3') %>

            <!-- Page 4: Additional Information -->
            <%- include('data_forms/formpage4') %>

            <!-- Page 5: Particle Details -->
            <%- include('data_forms/formpage5') %>

            <!-- Page 6: Review and Submit -->
            <template id="template-form-page6">
                <div class="form-page" id="form-page6" data-page="6">
                    <h2 class="form-section-title">Review and Submit</h2>
                    <div class="form-section">
                        <div class="confirmation-message">
                            <p>Please review your data before final submission. You can go back to previous pages to make changes if needed.</p>
                        </div>
                        <div class="data-summary">
                            <h3>Data Summary
                                <button type="button" onclick="if(window.generateSummary) window.generateSummary(); else console.log('generateSummary not available');" style="margin-left: 10px; padding: 5px 10px; font-size: 12px; background: #007bff; color: white; border: none; border-radius: 3px; cursor: pointer;">Refresh Summary</button>
                            </h3>
                            <div id="summary-container">
                                <!-- Summary will be populated by JavaScript -->
                            </div>
                        </div>
                        <div class="form-row">
                            <label class="form-label">Additional Notes:</label>
                            <textarea name="additional_notes" class="form-textarea" placeholder="Any additional information you'd like to provide..."></textarea>
                        </div>
                    </div>
                    <div class="form-navigation">
                        <button type="button" id="save-button" class="btn-save">Save and Continue</button>

                        <!-- Next Steps Options (shown after successful save) -->
                        <div id="next-steps-options" class="next-steps-container" style="display: none;">
                            <h3>Data Saved Successfully! What would you like to do next?</h3>
                            <div class="next-steps-buttons">
                                <button type="button" id="new-location-date" class="btn-option">
                                    <strong>A) Start New Location/Date</strong>
                                    <br><small>Begin fresh data entry for a different location and date</small>
                                </button>
                                <button type="button" id="different-media" class="btn-option">
                                    <strong>B) Different Media Type</strong>
                                    <br><small>Change media type for same location and date</small>
                                </button>
                                <button type="button" id="same-media-sample" class="btn-option">
                                    <strong>C) Additional Sample</strong>
                                    <br><small>Add another sample for same media, location, and date</small>
                                </button>
                            </div>
                            <div class="next-steps-note">
                                <p><em>Choose your next action to continue data entry efficiently.</em></p>
                            </div>
                        </div>
                    </div>
                </div>
            </template>
        </div>
        
        <!-- Form data will be submitted through AJAX -->
        <form id="data-entry-form" style="display:none;">
            <input type="hidden" name="form_action" value="save_data">
            <!-- Hidden inputs will be populated with form data before submission -->
        </form>    </div>
</div>

<%- include('partials/timeout_modal') %>

<!-- Load jQuery first -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<!-- Load session timeout script -->
<script src="/js/session-timeout.js"></script>
<!-- Load other scripts -->
<script src="https://unpkg.com/leaflet@1.7.1/dist/leaflet.js"></script>
<script src="/js/map-data-entry.js"></script>
<!-- Load fancy modal before form-handler -->
<script src="/js/fancy-modal.js"></script>
<script src="/js/form-handler.js"></script>

<script>
// Clear all form cache and initialize form data storage on page load
document.addEventListener('DOMContentLoaded', function() {
    console.log('=== EJS DOMContentLoaded event triggered ===');
    
    // Clear all cached form data to start fresh
    console.log('Clearing all form cache...');
    sessionStorage.removeItem('microplastics_form_data');
    
    // Also clear any other potential form-related cache keys
    const keysToRemove = [];
    for (let i = 0; i < sessionStorage.length; i++) {
        const key = sessionStorage.key(i);
        if (key && (key.includes('form') || key.includes('microplastics') || key.includes('packaging'))) {
            keysToRemove.push(key);
        }
    }
    keysToRemove.forEach(key => sessionStorage.removeItem(key));
    
    // Initialize fresh session storage for form data
    sessionStorage.setItem('microplastics_form_data', JSON.stringify({}));
    console.log('Form cache cleared and reinitialized.');
    
    // Clear all form fields in the visible page
    clearAllFormFields();
    
    // Function to clear all form fields
    function clearAllFormFields() {
        console.log('Clearing all form fields...');
        
        // Clear all input fields
        const inputs = document.querySelectorAll('input');
        inputs.forEach(input => {
            if (input.type === 'text' || input.type === 'number' || input.type === 'email' || 
                input.type === 'date' || input.type === 'password' || input.type === 'tel' || 
                input.type === 'url' || input.type === 'search') {
                input.value = '';
            } else if (input.type === 'checkbox' || input.type === 'radio') {
                input.checked = false;
            } else if (input.type === 'hidden') {
                // Don't clear hidden inputs for CSRF tokens, etc.
                if (!input.name.includes('csrf') && !input.name.includes('token')) {
                    input.value = '';
                }
            }
        });
        
        // Clear all select fields
        const selects = document.querySelectorAll('select');
        selects.forEach(select => {
            select.selectedIndex = 0; // Reset to first option (usually empty option)
        });
        
        // Clear all textarea fields
        const textareas = document.querySelectorAll('textarea');
        textareas.forEach(textarea => {
            textarea.value = '';
        });
        
        console.log('All form fields cleared.');
    }
    
    // Also disable browser autofill to prevent refilling after we clear
    const formElements = document.querySelectorAll('input, select, textarea');
    formElements.forEach(element => {
        element.setAttribute('autocomplete', 'off');
    });
    
    // Force clear any browser-cached values after a short delay
    setTimeout(() => {
        clearAllFormFields();
        console.log('Second pass form field clearing completed.');
    }, 100);
    
    // Additional cleanup when page is fully loaded
    window.addEventListener('load', function() {
        console.log('Page fully loaded, performing final cache cleanup...');
        clearAllFormFields();
        
        // Clear any localStorage items that might interfere
        const localStorageKeysToRemove = [];
        for (let i = 0; i < localStorage.length; i++) {
            const key = localStorage.key(i);
            if (key && (key.includes('form') || key.includes('microplastics') || key.includes('packaging'))) {
                localStorageKeysToRemove.push(key);
            }
        }
        localStorageKeysToRemove.forEach(key => localStorage.removeItem(key));
          console.log('Final cleanup completed.');
        
        // Reset the initial page load flag to ensure proper behavior on refresh
        if (typeof window.isPageInitialLoad !== 'undefined') {
            window.isPageInitialLoad = true;
        }
    });

    // Pre-fill form with any data already in the session
    const formData = JSON.parse(sessionStorage.getItem('microplastics_form_data'));
    for (const key in formData) {
        const element = document.querySelector(`[name="${key}"]`);
        if (element) {
            if (element.type === 'checkbox' || element.type === 'radio') {
                element.checked = formData[key];
            } else {
                element.value = formData[key];
            }
        }
    }
      // Set up event listeners for Continue buttons - HANDLED BY form-handler.js
    // document.querySelector('.form-pages-container').addEventListener('click', function(event) {
    //     if (event.target.classList.contains('btn-continue')) {
    //         const nextPage = parseInt(event.target.dataset.next);
    //         
    //         // Save current form data before moving to next page
    //         saveCurrentFormData();
    //         
    //         // Load the next page
    //         loadNextPage(nextPage);
    //         
    //         // Update progress indicator
    //         updateProgressSteps(nextPage);
    //     }
    // });
    
    // Set up event listeners for media type selection changes
    document.addEventListener('change', function(event) {
        if (event.target.name === 'media_type') {
            // Show/hide media-specific sections in page 3
            const mediaSpecificSections = document.querySelectorAll('.media-specific-section');
            mediaSpecificSections.forEach(section => {
                if (section.dataset.mediaType === event.target.value) {
                    section.style.display = 'block';
                } else {
                    section.style.display = 'none';
                }
            });
        }
        
        if (event.target.classList.contains('toggle-additional-info')) {
            const additionalInfoSections = document.getElementById('additional-info-sections');
            if (event.target.value === 'yes') {
                additionalInfoSections.style.display = 'block';
            } else {
                additionalInfoSections.style.display = 'none';
            }
        }
        
        if (event.target.name === 'has_quantitative_data') {
            const quantitativeContainer = document.getElementById('quantitative-counts-container');
            if (quantitativeContainer) {
                if (event.target.value === 'yes') {
                    quantitativeContainer.style.display = 'block';
                } else {
                    quantitativeContainer.style.display = 'none';
                    // Also hide detail sections
                    const microplasticsDetails = document.getElementById('microplastics-details');
                    const fragmentsDetails = document.getElementById('fragments-details');
                    const packagingDetails = document.getElementById('packaging-details');

                    if (microplasticsDetails) microplasticsDetails.style.display = 'none';
                    if (fragmentsDetails) fragmentsDetails.style.display = 'none';
                    if (packagingDetails) packagingDetails.style.display = 'none';
                }
            }
        }
    });
    
    // Set up event listeners for particle count inputs
    document.addEventListener('input', function(event) {
        if (event.target.id === 'microplastics-count') {
            const count = parseInt(event.target.value) || 0;
            const detailsSection = document.getElementById('microplastics-details');
            if (detailsSection) {
                detailsSection.style.display = count > 0 ? 'block' : 'none';
            }
        }

        if (event.target.id === 'fragments-count') {
            const count = parseInt(event.target.value) || 0;
            const detailsSection = document.getElementById('fragments-details');
            if (detailsSection) {
                detailsSection.style.display = count > 0 ? 'block' : 'none';
            }
        }
        
        if (event.target.id === 'packaging-count') {
            const count = parseInt(event.target.value) || 0;
            const detailsSection = document.getElementById('packaging-details');
            const itemsContainer = document.getElementById('packaging-items-container');

            // Check if elements exist before manipulating them
            if (!itemsContainer || !detailsSection) {
                console.warn('Packaging elements not found - page may not be loaded yet');
                return;
            }

            if (count > 0) {
                detailsSection.style.display = 'block';

                // Create packaging item forms
                itemsContainer.innerHTML = '';
                const template = document.getElementById('packaging-item-template');

                if (!template) {
                    console.warn('Packaging item template not found');
                    return;
                }

                for (let i = 1; i <= count; i++) {
                    const itemElement = template.content.cloneNode(true);
                    itemElement.querySelector('.item-number').textContent = i;
                    itemsContainer.appendChild(itemElement);
                }
            } else {
                detailsSection.style.display = 'none';
            }
        }
    });
    
    // Set up save button - DISABLED, now handled by form-handler.js
    // document.addEventListener('click', function(event) {
    //     if (event.target.id === 'save-button') {
    //         submitFormData();
    //     }
    // });
    
    // Function to save current form data to session storage
    function saveCurrentFormData() {
        const currentFormData = JSON.parse(sessionStorage.getItem('microplastics_form_data'));
        const formElements = document.querySelectorAll('.form-pages-container input, .form-pages-container select, .form-pages-container textarea');
        
        formElements.forEach(element => {
            if (element.name) {
                if (element.type === 'checkbox' || element.type === 'radio') {
                    if (element.checked) {
                        currentFormData[element.name] = element.value;
                    }
                } else {
                    currentFormData[element.name] = element.value;
                }
            }
        });
        
        sessionStorage.setItem('microplastics_form_data', JSON.stringify(currentFormData));
    }
    
    // Function to load the next form page
    function loadNextPage(pageNumber) {
        // Get the template content
        const template = document.getElementById('template-form-page' + pageNumber);
        if (!template) return;
        
        // Clone the template content
        const pageContent = template.content.cloneNode(true);
        
        // Append to the form pages container
        document.querySelector('.form-pages-container').appendChild(pageContent);
        
        // Pre-fill the newly added page with any existing data
        const formData = JSON.parse(sessionStorage.getItem('microplastics_form_data'));
        const newPage = document.getElementById('form-page' + pageNumber);
        
        if (newPage) {
            const formElements = newPage.querySelectorAll('input, select, textarea');
            formElements.forEach(element => {
                if (element.name && formData[element.name]) {
                    if (element.type === 'checkbox' || element.type === 'radio') {
                        element.checked = (formData[element.name] === element.value);
                    } else {
                        element.value = formData[element.name];
                    }
                }
            });
        }
        
        // Scroll to the new page
        newPage.scrollIntoView({ behavior: 'smooth' });
    }
    
    // Function to update progress steps
    function updateProgressSteps(activeStep) {
        const steps = document.querySelectorAll('.progress-step');
        steps.forEach(step => {
            const stepNumber = parseInt(step.dataset.step);
            if (stepNumber <= activeStep) {
                step.classList.add('active');
            }
        });
    }
    
    // Function to submit the form data
    function submitFormData() {
        // Display a loading indicator
        const loadingIndicator = document.createElement('div');
        loadingIndicator.className = 'loading-indicator';
        loadingIndicator.innerHTML = '<div class="spinner"></div><p>Saving data...</p>';
        document.body.appendChild(loadingIndicator);
        
        // Get all form data from session storage
        const formData = JSON.parse(sessionStorage.getItem('microplastics_form_data'));
        
        // Submit via AJAX
        fetch('/api/save-form-data', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(formData)
        })
        .then(response => response.json())
        .then(data => {
            // Remove loading indicator
            document.body.removeChild(loadingIndicator);
            
            if (data.success) {
                // Clear session storage
                sessionStorage.removeItem('microplastics_form_data');
                
                // Show success message and redirect
                alert('Data saved successfully!');
                window.location.href = '/review';
            } else {
                alert('Error saving data: ' + data.message);
            }
        })
        .catch(error => {
            // Remove loading indicator
            document.body.removeChild(loadingIndicator);
            console.error('Error:', error);
            alert('Error saving data. Please try again.');
        });
    }
    
    // Add CSS for loading indicator and other form styles
    const style = document.createElement('style');
    style.textContent = `
        .loading-indicator {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 9999;
        }
        .loading-indicator p {
            color: white;
            margin-top: 10px;
        }
        .spinner {
            border: 5px solid #f3f3f3;
            border-top: 5px solid #3498db;
            border-radius: 50%;
            width: 50px;
            height: 50px;
            animation: spin 2s linear infinite;
        }
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    `;
    document.head.appendChild(style);
});
</script>

<%- include('partials/footer') %>
