<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="icon" href="/assets/mpicon.ico" sizes="64x64">
    <link rel="stylesheet" href="/css/auth-pages.css">
</head>
<body>
    <div class="container">
        <div class="header">
            <div class="logo-container">
                <a href="/home">
                    <img src="/assets/Logo-MicroPlastics_09.png" alt="MicroPlastics Logo">
                </a>
            </div>
            <h1 class="form-title">Reset Link Expired</h1>
            <p class="form-subtitle">This password reset link is no longer valid</p>
        </div>
        
        <div class="form-container">
            <div class="alert alert-warning" style="text-align: center;">
                <div style="font-size: 48px; margin-bottom: 15px;">⏰</div>
                <h3 style="margin: 0 0 15px 0; color: #856404;">Link Has Expired</h3>
                <p style="margin: 0 0 15px 0;">
                    This password reset link has expired or has already been used. 
                    For security reasons, password reset links can only be used once and expire after 1 hour.
                </p>
                <p style="margin: 0 0 20px 0;">
                    Please request a new password reset link to continue.
                </p>
                
                <div style="display: flex; gap: 10px; justify-content: center; flex-wrap: wrap;">
                    <a href="/auth/reset-password" class="btn" style="text-decoration: none; margin: 5px;">
                        🔄 Request New Reset Link
                    </a>
                    <a href="/home" class="btn" style="text-decoration: none; margin: 5px; background-color: #6c757d;">
                        🏠 Return to Home
                    </a>
                </div>
            </div>
            
            <div style="background-color: #f8f9fa; padding: 20px; border-radius: 6px; margin-top: 20px;">
                <h4 style="margin: 0 0 10px 0; color: var(--text-color);">💡 Security Tips:</h4>
                <ul style="margin: 0; padding-left: 20px; color: #666;">
                    <li>Password reset links expire after 1 hour for security</li>
                    <li>Each link can only be used once</li>
                    <li>Always request a new link if the old one doesn't work</li>
                    <li>Check your spam folder if you don't receive the email</li>
                </ul>
            </div>
        </div>
        
        <div class="form-footer">
            <p><a href="/login">← Back to Login</a></p>
            <p>Don't have an account? <a href="/signup">Sign up here</a></p>
        </div>
    </div>

    <!-- Disable Stagewise Toolbar for auth pages -->
    <% if (false && process.env.NODE_ENV !== 'production') { %>
        <script src="/js/stagewise-toolbar.js"></script>
    <% } %>
</body>
</html>
