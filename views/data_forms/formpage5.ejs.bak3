                    </div>
                    <div class="form-row">
                        <label class="form-label">Pellet:</label>
                        <input type="number" name="fragment_form_pellet" class="form-input" placeholder="percentage" min="0" max="100">
                    </div>
                    <div class="form-row">
                        <label class="form-label">Film/Bag/Wrap:</label>
                        <input type="number" name="fragment_form_film" class="form-input" placeholder="percentage" min="0" max="100">
                    </div>
                    <div class="form-row">
                        <label class="form-label">Foam:</label>
                        <input type="number" name="fragment_form_foam" class="form-input" placeholder="percentage" min="0" max="100">
                    </div>
                    <div class="form-row">
                        <label class="form-label">HardPlastic:</label>
