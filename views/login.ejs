<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="icon" href="/assets/mpicon.ico" sizes="64x64">    <link rel="stylesheet" href="/css/auth-pages.css">
</head>
<body>
    <div class="container">
        <div class="header">
            <div class="logo-container">
                <a href="/home">
                    <img src="/assets/Logo-MicroPlastics_09.png" alt="MicroPlastics Logo">
                </a>
            </div>
            <h1 class="form-title">Login</h1>
            <p class="form-subtitle">Access your account</p>
        </div>
        
        <div class="form-container">
            <% if (locals.error) { %>
                <div class="error-message">
                    <%= error %>
                </div>
            <% } %>
            
            <form id="loginForm" action="/auth/login" method="POST">
                <div class="form-group">
                    <label class="form-label" for="login">Username or Email:</label>
                    <input type="text" id="login" name="login" class="form-input" required>
                </div>
                
                <div class="form-group">
                    <label class="form-label" for="password">Password:</label>
                    <input type="password" id="password" name="password" class="form-input" required>
                </div>
                
                <div class="form-group">
                    <label class="form-label" for="captcha">Verification Code:</label>
                    <div class="captcha-container">
                        <img id="captcha-image" src="/auth/captcha" alt="Captcha" class="captcha-image" 
                             onclick="refreshCaptcha()" title="Click to refresh">
                        <input type="text" id="captcha" name="captcha" class="form-input captcha-input" 
                               placeholder="Enter code" required>
                    </div>
                </div>
                
                <div class="checkbox-container">
                    <input type="checkbox" id="remember" name="remember" value="1">
                    <label for="remember">Remember me for 30 days</label>
                </div>
                
                <button type="submit" class="btn">Login</button>
            </form>
        </div>
          <div class="form-footer">
            <p>Don't have an account? <a href="/signup">Sign up here</a></p>
            <p><a href="/auth/reset-password">Forgot your password?</a></p>
        </div>
    </div>    <script>
        function refreshCaptcha() {
            const captchaImage = document.getElementById('captcha-image');
            captchaImage.src = '/auth/captcha?' + Math.random();
            document.getElementById('captcha').value = '';
        }    </script>    <script src="/js/auth.js"></script>
    
    <!-- Disable Stagewise Toolbar for auth pages -->
    <% if (false && process.env.NODE_ENV !== 'production') { %>
        <script src="/js/stagewise-toolbar.js"></script>
    <% } %>
</body>
</html>
