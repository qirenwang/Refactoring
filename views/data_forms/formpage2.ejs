<!-- Page 2: Sampling Event -->
<template id="template-form-page2">
    <div class="form-page" id="form-page2" data-page="2">
        <h2 class="form-section-title">Sampling Event Information</h2>
        <div class="form-section">
            <div class="instruction">
                Please provide information about when and how you collected your sample.
            </div>
              <!-- Device Installation Period Question -->
               <div class="form-label" style="margin-bottom: 12px;">Did this sample come from a device that was installed for a period of time (with a start and end date)?</div>
            <div class="form-field">                            <div class="radio-group" style="margin-left: 20px;">
                    <div class="radio-option">
                        <input type="radio" id="device-period-no" name="device_installation_period" value="no" checked>
                        <label for="device-period-no">No - Single collection event</label>
                    </div>
                    <div class="radio-option">
                        <input type="radio" id="device-period-yes" name="device_installation_period" value="yes">
                        <label for="device-period-yes">Yes - Device was installed for a period of time</label>
                    </div>
                </div>
            </div>
            
            <!-- Single Collection Date (Default) -->
            <div class="form-field" id="single-collection-section">
                <div class="form-label">Plastic Collection Date (<span style="color: red;">*</span>):</div>
                <div>
                    <input type="date" name="sample_date" class="date-input" id="sample-date" placeholder="mm/dd/yyyy">
                </div>
            </div>
            
            <!-- Device Installation Period Dates (Hidden by default) -->
            <div class="form-field" id="device-period-section" style="display: none;">
                <div class="date-range-container">
                    <div class="date-range-field">
                        <div class="form-label">Device Installation Start Date (<span style="color: red;">*</span>):</div>
                        <div>
                            <input type="date" name="device_start_date" class="date-input" id="device-start-date">
                        </div>
                    </div>
                    <div class="date-range-field">
                        <div class="form-label">Device Removal/End Date (<span style="color: red;">*</span>):</div>
                        <div>
                            <input type="date" name="device_end_date" class="date-input" id="device-end-date">
                        </div>
                    </div>
                </div>
            </div>
              <div class="form-field">
                <div class="form-label">Collection Time (optional):</div>
                <div>
                    <input type="time" name="sample_time" class="time-input-wide" id="sample-time">
                </div>
            </div>
            
            <div class="form-field">
                <div class="form-label">Sample Description (optional):</div>
                <div>
                    <textarea name="sample_description" class="form-textarea-wide" id="sample-description" placeholder="Brief description of your sampling event..." rows="2"></textarea>
                </div>
            </div>
        </div>
        <!-- Weather section - Always shown when additional info is yes -->
                <div class="info-section" id="weather-section">
                    <h3 class="section-subtitle">Weather</h3>
                    <div class="form-row">
                        <label class="form-label">Air Temp (C):</label>
                        <input type="number" step="0.1" name="air_temp" class="form-input" placeholder="Enter temperature">
                    </div>
                    <div class="form-row">
                        <label class="form-label">Weather Conditions at Time of Sampling:</label>
                        <select name="current_conditions" class="form-select">
                            <option value="">-- Select --</option>
                            <option value="Raining">Raining</option>
                            <option value="Cloudy">Cloudy</option>
                            <option value="Sunny">Sunny</option>
                        </select>
                    </div>
                    <div class="form-row">
                        <label class="form-label">Precedent 24-hour cm of rainfall:</label>
                        <input type="number" step="0.01" name="rainfall" class="form-input" placeholder="Enter rainfall">
                    </div>
                </div>
        <div class="form-navigation">
            <button type="button" id="page2-continue" class="btn-continue" data-next="3">Continue</button>
        </div>
    </div>
</template>
