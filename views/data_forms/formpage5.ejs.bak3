            <!-- Whole Packaging Details Section -->
            <div id="packaging-details" class="form-section details-section" style="display:none;">
                <h3>Whole Packaging Details</h3>
                <p>First provide the number of items in each category, then provide details for each category as needed:</p>
                
                <!-- Purpose Categories with Inline Details -->
                <div class="purpose-overview">
                    <h4>Number of Items by Purpose Category</h4>

                    <!-- Single-Use Food/Beverage Container with inline details -->
                    <div class="purpose-category-block">
                        <div class="form-row">
                            <label class="form-label">Single-Use Food/Beverage Container:</label>
                            <input type="number" name="packaging_count_single_use" class="form-input" min="0" placeholder="0">
                        </div>

                        <!-- Single-Use Details (Optional) - Inline -->
                        <div class="inline-category-details" style="margin-left: 20px; margin-top: 15px; padding: 15px; background-color: #f9f9f9; border-radius: 8px;">
                            <h5 style="margin-bottom: 15px; color: #666;">Container Single-Use Food/Beverage Details (Optional)</h5>
                            <div class="category-grid-compact">
                                <div class="left-stack">
                                    <div class="category-section">
                                        <h5>Recycle Code</h5>
                                        <div class="recycle-codes-grid compact-grid">
                                            <div class="form-row"><label class="form-label">1 (PET):</label><input type="number" name="single_use_recycle_1" class="form-input" min="0" placeholder="0"></div>
                                            <div class="form-row"><label class="form-label">2 (HDPE):</label><input type="number" name="single_use_recycle_2" class="form-input" min="0" placeholder="0"></div>
                                            <div class="form-row"><label class="form-label">3 (PVC):</label><input type="number" name="single_use_recycle_3" class="form-input" min="0" placeholder="0"></div>
                                            <div class="form-row"><label class="form-label">4 (LDPE):</label><input type="number" name="single_use_recycle_4" class="form-input" min="0" placeholder="0"></div>
