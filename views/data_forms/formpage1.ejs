<!-- Page 1: Location Information - Initially visible -->
<div class="form-page" id="form-page1" data-page="1">
    <h2 class="form-section-title">Location Information</h2>
    <div class="instruction">
    To manage locations, click user name at upper right corner and select My Locations.
    </div>
    <div class="instruction">
        <span class="bold">Choose ONE</span> of the 2 ways below to enter the sampling location. Reuse a previous location for repeat sampling, or enter a new location and then provide location details using coordinates, a full indoor address, or a ZIP code for approximate area only.
    </div>
    <div class="location-options">
        <div class="option">
            <span class="option-number">1</span>
            <span class="option-title">Select previously sampled location</span> (repeat sampling)
            <div class="select-container">
                <select id="location-select" class="location-select" name="location_id">
                    <option value="">-- Select a location --</option>
                </select>
                <div id="location-loading" class="location-loading">Loading locations...</div>
            </div>
        </div>                    <div class="option">
            <span class="option-number">2</span>
            <!-- # add a note here -->
            <span class="option-title">Enter new location</span>
            <div class="instruction-note" style="color: #e74c3c; background-color: #fdf2f2; padding: 8px; margin: 8px 0; border-left: 4px solid #e74c3c; font-size: 14px;">
                <strong>Important:</strong> To create a brand new location, clear "Select previously sampled location" first. If an existing location is selected, only location description and coordinates are treated as event-level overrides.
            </div>
            <div class="location-form">                            <div class="form-row">
                    <label class="form-label">Location Name (<span style="color: red;">*</span>):</label>
                </div>
                <div class="form-row">
                    <input type="text" id="location-name" name="location_name" class="form-input" placeholder="Enter location name">
                </div>
                <div class="form-row">
                    <label class="form-label">Location Short Code (<span style="color: red;">*, for quickly identifying location types, such as a storm drain or lake, see documentation</span>):</label>
                </div>
                <div class="form-row">
                    <input type="text" id="location-shortcode" name="location_shortcode" class="form-input" placeholder="For quickly identifying location types, such as a storm drain or lake, see documentation.">
                </div>
                <div class="form-row">
                    <label class="form-label">Location Description :</label>
                </div>
                <div class="form-row">
                    <input type="text" id="location-description" name="location_description" class="form-input" placeholder="Enter location description">
                </div>

                <div class="form-row">
                    <label class="form-label">Land Use and Land Cover (LULC) (<span style="color: red;">*</span>):</label>
                </div>
                <div class="form-row">
                    <select id="land-use-cover" name="land_use_cover" class="form-input" required>
                        <option value="">-- Select Land Use and Land Cover --</option>
                        <option value="water">Water</option>
                        <option value="trees">Trees</option>
                        <option value="flooded_vegetation">Flooded Vegetation</option>
                        <option value="crops">Crops</option>
                        <option value="built_area">Built Area</option>
                        <option value="bare_ground">Bare Ground</option>
                        <option value="snow_ice">Snow/Ice</option>
                        <option value="rangeland">Rangeland</option>
                    </select>
                </div>

                

                <div class="instruction">
                    For new locations, use <span class="bold">latitude/longitude</span> for precise outdoor sampling points, <span class="bold">full address + Find Address on Map</span> for indoor samples, or <span class="bold">ZIP code</span> when you can only share an approximate area.
                </div>

                
                
                <span class="form-label"><span class="bold">For outdoor:</span></span>
                <div class="coordinates-container">
                    <div class="coordinate-field">
                        <div class="coordinate-label">Latitude (click map)</div>
                        <input type="text" id="latitude" name="latitude" class="coordinate-input" placeholder="Enter latitude">
                    </div>
                    <div class="coordinate-field">
                        <div class="coordinate-label">Longitude</div>
                        <input type="text" id="longitude" name="longitude" class="coordinate-input" placeholder="Enter longitude">
                    </div>
                </div>
                
                <div class="coordinate-hint">Click the map to set coordinates, drag the marker to refine them, or type latitude and longitude manually.</div>
                
                <!-- Map container -->
                <div id="map"></div>

                <span class="form-label">Or ZIP code</span> (for confidential data or samples collected over a wide area):
                <div class="coordinate-hint" style="margin-top: 6px;">ZIP code is kept for approximate area reporting only. It will not place a precise point on the map.</div>
                <input type="text" name="zip_code" class="input-field" placeholder="zip code">
                
                <div class="form-row">
                    <label class="form-label">Square kilometer (km²) if sampling a broad area:</label>
                    <input type="text" id="acres" name="acres" class="form-input" placeholder="Enter area in km²">
                </div>


                <span class="form-label"><span class="bold">For indoor:</span> Full address</span>
                <div class="instruction-note" style="color: #e74c3c; background-color: #fdf2f2; padding: 8px; margin: 8px 0; border-left: 4px solid #e74c3c; font-size: 14px;">
                <strong>Important:</strong> ONLY enter address if the sample was collected indoors. All environmental samples should have either latitude/longitude or ZIP code. We will assume the sample came from indoors if you provide an address.
                </div>
                <div class="coordinate-hint" style="margin-top: 6px;">Enter the full address, then select <span class="bold">Find Address on Map</span> to place the marker. Review the point and drag it if needed.</div>
                <input type="text" name="streetaddress" class="input-field" placeholder="StreetAddress">
                <div style="display: flex; gap: 8px; margin-top: 8px;">
                    <input type="text" name="city" class="input-field" placeholder="City" style="flex:1;">
                    <input type="text" name="state" class="input-field" placeholder="State" style="flex:1;">
                    <input type="text" name="country" class="input-field" placeholder="Country" style="flex:1;">
                </div>
                <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap; margin-top: 10px;">
                    <button type="button" id="find-address-on-map" class="btn-continue" style="width: auto; padding: 8px 14px;">Find Address on Map</button>
                    <div id="address-geocode-status" style="font-size: 13px; line-height: 1.4;"></div>
                </div>
                

                
            </div>

            
        </div>

        
    </div>
    <div class="form-navigation">
        <button type="button" id="page1-continue" class="btn-continue" data-next="2">Continue</button>
    </div>
</div>
